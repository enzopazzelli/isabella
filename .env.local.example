# ---- Sync con Google Sheets via Apps Script ----
# URL que devuelve Apps Script al hacer "Deploy → Web app"
# (termina en /exec). Si esta vacio, el sync se desactiva silenciosamente.
APPS_SCRIPT_URL=

# Secreto compartido entre este sitio y el Apps Script.
# Tiene que coincidir EXACTO con la Script Property "SYNC_SECRET" del Apps Script.
# Genera uno largo y random (ej: openssl rand -hex 32).
SYNC_SECRET=

# ---- Admin ----
# Contrasena del panel de administracion. Sin esto, en produccion el
# panel rechaza todo login. En dev local sin setear, el password es
# "isabella-dev" (fallback solo cuando NODE_ENV !== 'production').
ADMIN_PASSWORD=

# ---- Google Sheet ----
# ID del spreadsheet (entre /d/ y /edit en la URL). Vacio = usa los
# defaults estaticos definidos en lib/defaults.js.
NEXT_PUBLIC_SHEET_ID=
